@page "/"
@using Shared
@using WEB.Services
@rendermode InteractiveServer
@inject ApiClient Api

<h3>Encounter Builder</h3>



<div class="page-layout">
    <div class="left-panel">
        <h3>Monsters</h3>
        <div class="monster-list">
            <div class="monster-toolbar">
                <input @bind="searchTerm" placeholder="Search monsters..." />

                <select @bind="selectedSort">
                    <option value="name-asc">Name A-Z</option>
                    <option value="name-desc">Name Z-A</option>
                    <option value="cr-asc">CR Low to High</option>
                    <option value="cr-desc">CR High to Low</option>
                </select>

                <select @bind="selectedCrFilter">
                    <option value="">All CR</option>
                    <option value="0">0</option>
                    <option value="0.125">1/8</option>
                    <option value="0.25">1/4</option>
                    <option value="0.5">1/2</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                    <option value="8">8</option>
                    <option value="9">9</option>
                    <option value="10">10</option>
                    <option value="11">11</option>
                    <option value="12">12</option>
                    <option value="13">13</option>
                    <option value="14">14</option>
                    <option value="15">15</option>
                    <option value="16">16</option>
                    <option value="17">17</option>
                    <option value="18">18</option>
                    <option value="19">19</option>
                    <option value="20">20</option>
                    <option value="21">21</option>
                    <option value="22">22</option>
                    <option value="23">23</option>
                    <option value="24">24</option>
                    <option value="25">25</option>
                    <option value="26">26</option>
                    <option value="27">27</option>
                    <option value="28">28</option>
                    <option value="29">29</option>
                    <option value="30">30</option>
                </select>
            </div>

            <p>Showing @filteredMonsters.Count() of @monsters.Count monsters</p>

            <h4>Available Monsters</h4>
            <ul>
                @if (isLoading)
                {
                    <p>Loading monsters...</p>
                }
                @foreach (var monster in filteredMonsters)
                {
                    <li>
                        @monster.Name (CR @FormatCr(monster.ChallengeRating), XP @monster.Xp)
                        <button @onclick="() => AddMonster(monster)">Add</button>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="right-panel">
        <div class="party-card">
            <h4>Party</h4>

            <div>
                <label>Party Size: </label>
                <input type="number" min="1" @bind="partySize" />
            </div>

            <div>
                <label>Party Level: </label>
                <input type="number" min="1" max="20" @bind="partyLevel" />
            </div>

          
        </div>

        <div class="encounter-card">
            <h4>Selected Encounter</h4>

            @if (selectedMonsters.Count == 0)
            {
                <p>No monsters added yet.</p>
            }
            else
            {
                <ul>
                    @foreach (var selected in selectedMonsters)
                    {
                        <li>
                            @selected.Name
                            Quantity: @selected.Quantity

                            <button @onclick="() => IncreaseQuantity(selected.MonsterId)">+</button>
                            <button @onclick="() => DecreaseQuantity(selected.MonsterId)">-</button>
                            <button @onclick="() => RemoveMonster(selected.MonsterId)">Remove</button>
                        </li>
                    }
                </ul>
            }

        </div>

        <div class="result-card">
            <button type="button" @onclick="CalculateEncounter">Calculate</button>
            
            <h4>Encounter Result</h4>

            @if (calculationResult is null)
            {
                <p>No calculation yet.</p>
            }
            else
            {
                <ul>
                    <li>Easy Threshold: @calculationResult.PartyEasyThreshold</li>
                    <li>Medium Threshold: @calculationResult.PartyMediumThreshold</li>
                    <li>Hard Threshold: @calculationResult.PartyHardThreshold</li>
                    <li>Deadly Threshold: @calculationResult.PartyDeadlyThreshold</li>
                    <li>Raw Monster XP: @calculationResult.RawMonsterXp</li>
                    <li>Monster Multiplier: @calculationResult.MonsterMultiplier</li>
                    <li>Adjusted Monster XP: @calculationResult.AdjustedMonsterXp</li>
                    <li>Monster Count: @calculationResult.MonsterCount</li>
                    <li>Difficulty: <strong>@calculationResult.Difficulty</strong></li>
                </ul>
            }

            
        </div>
    </div>
</div>
<p>Status: @statusMessage</p>

@code {
    private List<MonsterListItemDto> monsters = new();
    private List<SelectedMonsterViewModel> selectedMonsters = new();
    private string statusMessage = "Nothing loaded yet.";
    private int partySize = 4;
    private int partyLevel = 1;
    private EncounterCalculationResponseDto? calculationResult;
    private string searchTerm = "";
    private string selectedSort = "name-asc";
    private string selectedCrFilter = "";
    private bool isLoading = false;

    
    protected override async Task OnInitializedAsync()
    {
        await LoadMonsters();
    }
    
    
    private async Task LoadMonsters()
    {
        try
        {
            isLoading = true;
            statusMessage = "Loading monsters...";

            monsters = await Api.GetMonstersAsync();

            statusMessage = $"Loaded {monsters.Count} monsters.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddMonster(MonsterListItemDto monster)
    {
        var existing = selectedMonsters.FirstOrDefault(m => m.MonsterId == monster.Id);

        if (existing is not null)
        {
            existing.Quantity++;
            return;
        }

        selectedMonsters.Add(new SelectedMonsterViewModel
        {
            MonsterId = monster.Id,
            Name = monster.Name,
            Xp = monster.Xp,
            ChallengeRating = monster.ChallengeRating,
            Quantity = 1
        });
    }

    private void IncreaseQuantity(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is not null)
        {
            monster.Quantity++;
        }
    }

    private void DecreaseQuantity(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is null)
            return;

        monster.Quantity--;

        if (monster.Quantity <= 0)
        {
            selectedMonsters.Remove(monster);
        }
    }

    private void RemoveMonster(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is not null)
        {
            selectedMonsters.Remove(monster);
        }
    }

    private class SelectedMonsterViewModel
    {
        public int MonsterId { get; set; }
        public string Name { get; set; } = "";
        public decimal ChallengeRating { get; set; }
        public int Xp { get; set; }
        public int Quantity { get; set; }
    }
    
    private async Task CalculateEncounter()
    {
        statusMessage = "Calculate clicked";
        StateHasChanged();

        try
        {
            var request = new EncounterCalculationRequestDto
            {
                PartyMembers = Enumerable.Range(0, partySize)
                    .Select(_ => new PartyMemberDto
                    {
                        Level = partyLevel
                    })
                    .ToList(),

                Monsters = selectedMonsters
                    .Select(m => new EncounterMonsterSelectionDto
                    {
                        MonsterId = m.MonsterId,
                        Quantity = m.Quantity
                    })
                    .ToList()
            };

            statusMessage = $"Sending request with {request.PartyMembers.Count} party members and {request.Monsters.Count} monster entries";
            StateHasChanged();

            calculationResult = await Api.CalculateAsync(request);

            if (calculationResult is null)
            {
                statusMessage = "API returned null result";
                return;
            }

            statusMessage = $"Encounter calculated: {calculationResult.Difficulty}";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
    
    private IEnumerable<MonsterListItemDto> filteredMonsters
    {
        get
        {
            IEnumerable<MonsterListItemDto> query = monsters;

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                query = query.Where(m =>
                    m.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(selectedCrFilter) &&
                decimal.TryParse(selectedCrFilter, out var cr))
            {
                query = query.Where(m => m.ChallengeRating == cr);
            }

            query = selectedSort switch
            {
                "name-desc" => query.OrderByDescending(m => m.Name),
                "cr-asc" => query.OrderBy(m => m.ChallengeRating).ThenBy(m => m.Name),
                "cr-desc" => query.OrderByDescending(m => m.ChallengeRating).ThenBy(m => m.Name),
                _ => query.OrderBy(m => m.Name)
            };

            return query;
        }
    }
    
    private static string FormatCr(decimal cr) => cr switch
    {
        0.125m => "1/8",
        0.25m => "1/4",
        0.5m => "1/2",
        _ => cr.ToString()
    };
}