@page "/"
@using Shared
@using WEB.Services
@rendermode InteractiveServer
@inject ApiClient Api

<div class="encounter-page">
    <h3>Encounter Builder</h3>
    <p class="encounter-subtitle">Build balanced battles and keep the danger under control.</p>
   

    <div class="page-layout">
    <div class="left-panel">
        <div class="panel-card">
            <h2>Monsters</h2>

            <div class="monster-toolbar">
                <input @bind="searchTerm" @bind:event="oninput" placeholder="Search monsters..." />
                <select @bind="selectedSort">
                    <option value="name-asc">Name A-Z</option>
                    <option value="name-desc">Name Z-A</option>
                    <option value="cr-asc">CR Low to High</option>
                    <option value="cr-desc">CR High to Low</option>
                </select>

                <select @bind="selectedCrFilter">
                    <option value="">All CR</option>
                    <option value="0">0</option>
                    <option value="0.125">1/8</option>
                    <option value="0.25">1/4</option>
                    <option value="0.5">1/2</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                    <option value="8">8</option>
                    <option value="9">9</option>
                    <option value="10">10</option>
                    <option value="11">11</option>
                    <option value="12">12</option>
                    <option value="13">13</option>
                    <option value="14">14</option>
                    <option value="15">15</option>
                    <option value="16">16</option>
                    <option value="17">17</option>
                    <option value="18">18</option>
                    <option value="19">19</option>
                    <option value="20">20</option>
                    <option value="21">21</option>
                    <option value="22">22</option>
                    <option value="23">23</option>
                    <option value="24">24</option>
                    <option value="25">25</option>
                    <option value="26">26</option>
                    <option value="27">27</option>
                    <option value="28">28</option>
                    <option value="29">29</option>
                    <option value="30">30</option>
                </select>
                <button type="button" @onclick="ResetFilters">Reset</button>
            </div>

            <p class="muted-text">Showing @FilteredMonsters.Count of @monsters.Count monsters</p>
            @if (isLoading)
            {
                <p>Loading monsters...</p>
            }
            else
            {
                <div class="monster-list">
                    @foreach (var monster in FilteredMonsters)
                    {
                        <div class="monster-row">
                            <div>
                                <strong>@monster.Name</strong>
                                <div class="muted-text">
                                    CR @FormatCr(monster.ChallengeRating), XP @monster.Xp, @monster.Type
                                </div>
                            </div>

                            @{
                                var selected = selectedMonsters.FirstOrDefault(m => m.MonsterId == monster.Id);
                            }

                            <div class="monster-actions">
                                @if (selected is null)
                                {
                                    <button type="button" @onclick="() => AddMonster(monster)">Add</button>
                                }
                                else
                                {
                                    <span class="muted-text">Added x @(selected.Quantity)</span>
                                    <button type="button" @onclick="() => AddMonster(monster)">+1</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="right-panel">
        <div class="panel-card">
            <h2>Party</h2>

            <div class="form-row">
                <label>Party Size</label>
                <input type="number" min="1" value="@partySize" @oninput="OnPartySizeChanged" />
            </div>

            <div class="form-row">
                <label>Party Level</label>
                <input type="number" min="1" max="20" value="@partyLevel" @oninput="OnPartyLevelChanged" />   
            </div>
        </div>

        <div class="panel-card encounter-card">
            <h2>Encounter</h2>

            <div class="section-button-row">
                <button type="button" @onclick="ClearEncounter">Clear Encounter</button>
            </div>

            @if (selectedMonsters.Count == 0)
            {
                <p class="muted-text" style="margin-top:10px;">No monsters added yet.</p>
            }
            else
            {
                <div class="encounter-list">
                    @foreach (var selected in selectedMonsters)
                    {
                        <div class="encounter-item">
                            <div>
                                <strong>@selected.Name</strong>
                                <div class="muted-text">
                                    CR @FormatCr(selected.ChallengeRating), XP @selected.Xp each
                                </div>
                                <div class="muted-text">
                                    Subtotal XP: @(selected.Xp * selected.Quantity)
                                </div>
                            </div>

                            <div class="encounter-controls">
                                <button type="button" @onclick="() => DecreaseQuantity(selected.MonsterId)">-</button>
                                <span class="qty-pill">@selected.Quantity</span>
                                <button type="button" @onclick="() => IncreaseQuantity(selected.MonsterId)">+</button>
                                <button type="button" @onclick="() => RemoveMonster(selected.MonsterId)">Remove</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
        <div class="panel-card">
            <h2>Summary</h2>

            <div class="summary-grid">
                <div class="summary-stat">
                    <span class="summary-stat-label">Total monsters</span>
                    <span class="summary-stat-value">@TotalMonsterCount</span>
                </div>

                <div class="summary-stat">
                    <span class="summary-stat-label">Unique monsters</span>
                    <span class="summary-stat-value">@selectedMonsters.Count</span>
                </div>

                <div class="summary-stat">
                    <span class="summary-stat-label">Total raw XP</span>
                    <span class="summary-stat-value">@TotalRawXp</span>
                </div>

                <div class="summary-stat">
                    <span class="summary-stat-label">Highest CR</span>
                    <span class="summary-stat-value">@FormatCr(HighestCr)</span>
                </div>
            </div>
        </div>

       <div class="panel-card result-card">
    <div class="result-top">
        <h2 style="margin:0;">Result</h2>

        <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
            @if (calculationResult is not null)
            {
                <span class="difficulty-badge @(GetDifficultyClass(calculationResult.Difficulty))">
                    @calculationResult.Difficulty
                </span>
            }

            <button type="button" @onclick="CalculateEncounter" disabled="@(!CanCalculate)">Calculate</button>
        </div>
    </div>

    @if (calculationResult is null)
    {
        <p class="muted-text">No calculation yet.</p>
    }
    else
    {
        <div class="result-grid">
            <div class="result-stat">
                <span class="result-stat-label">Easy Threshold</span>
                <span class="result-stat-value">@calculationResult.PartyEasyThreshold</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Medium Threshold</span>
                <span class="result-stat-value">@calculationResult.PartyMediumThreshold</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Hard Threshold</span>
                <span class="result-stat-value">@calculationResult.PartyHardThreshold</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Deadly Threshold</span>
                <span class="result-stat-value">@calculationResult.PartyDeadlyThreshold</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Raw Monster XP</span>
                <span class="result-stat-value">@calculationResult.RawMonsterXp</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Multiplier</span>
                <span class="result-stat-value">@calculationResult.MonsterMultiplier</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Adjusted XP</span>
                <span class="result-stat-value">@calculationResult.AdjustedMonsterXp</span>
            </div>

            <div class="result-stat">
                <span class="result-stat-label">Monster Count</span>
                <span class="result-stat-value">@calculationResult.MonsterCount</span>
            </div>
        </div>
    }

    <div class="status-line">
        Status: @statusMessage
    </div>
</div>
    </div>
</div>
</div>


@code {
    private List<MonsterListItemDto> monsters = new();
    private List<SelectedMonsterViewModel> selectedMonsters = new();
    private string statusMessage = "Nothing loaded yet.";
    private int partySize = 4;
    private int partyLevel = 1;
    private EncounterCalculationResponseDto? calculationResult;
    private string searchTerm = "";
    private string selectedSort = "name-asc";
    private string selectedCrFilter = "";
    private bool isLoading = false;
    private int TotalMonsterCount => selectedMonsters.Sum(m => m.Quantity);
    private int TotalRawXp => selectedMonsters.Sum(m => m.Xp * m.Quantity);
    private decimal HighestCr => selectedMonsters.Any()
        ? selectedMonsters.Max(m => m.ChallengeRating)
        : 0;
    private bool CanCalculate =>
        selectedMonsters.Any() &&
        partySize > 0 &&
        partyLevel is >= 1 and <= 20;
    private bool isCalculating = false;
    private string? errorMessage;
    private List<MonsterListItemDto> FilteredMonsters => GetFilteredMonsters().ToList();
    private static string GetDifficultyClass(DifficultyRating difficulty) => difficulty switch
    {
        DifficultyRating.Easy => "difficulty-easy",
        DifficultyRating.Medium => "difficulty-medium",
        DifficultyRating.Hard => "difficulty-hard",
        DifficultyRating.Deadly => "difficulty-deadly",
        _ => "difficulty-default"
    };
    

    
    protected override async Task OnInitializedAsync()
    {
        await LoadMonsters();
    }
    
    
    private async Task LoadMonsters()
    {
        try
        {
            isLoading = true;
            statusMessage = "Loading monsters...";

            monsters = await Api.GetMonstersAsync();

            statusMessage = $"Loaded {monsters.Count} monsters.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddMonster(MonsterListItemDto monster)
    {
        var existing = selectedMonsters.FirstOrDefault(m => m.MonsterId == monster.Id);

        if (existing is not null)
        {
            existing.Quantity++;
        }
        else
        {
            selectedMonsters.Add(new SelectedMonsterViewModel
            {
                MonsterId = monster.Id,
                Name = monster.Name,
                Xp = monster.Xp,
                ChallengeRating = monster.ChallengeRating,
                Quantity = 1
            });
        }

        await RecalculateIfPossible();
    }

    private async Task IncreaseQuantity(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is not null)
        {
            monster.Quantity++;
            await RecalculateIfPossible();
        }
    }

    private async Task DecreaseQuantity(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is null)
            return;

        monster.Quantity--;

        if (monster.Quantity <= 0)
        {
            selectedMonsters.Remove(monster);
        }

        await RecalculateIfPossible();
    }

    private async Task RemoveMonster(int monsterId)
    {
        var monster = selectedMonsters.FirstOrDefault(m => m.MonsterId == monsterId);
        if (monster is not null)
        {
            selectedMonsters.Remove(monster);
            await RecalculateIfPossible();
        }
    }

    private class SelectedMonsterViewModel
    {
        public int MonsterId { get; set; }
        public string Name { get; set; } = "";
        public decimal ChallengeRating { get; set; }
        public int Xp { get; set; }
        public int Quantity { get; set; }
    }
    
    private async Task CalculateEncounter()
    {
        try
        {
            isCalculating = true;
            errorMessage = null;
            statusMessage = "Calculating encounter...";

            var request = new EncounterCalculationRequestDto
            {
                PartyMembers = Enumerable.Range(0, partySize)
                    .Select(_ => new PartyMemberDto
                    {
                        Level = partyLevel
                    })
                    .ToList(),

                Monsters = selectedMonsters
                    .Select(m => new EncounterMonsterSelectionDto
                    {
                        MonsterId = m.MonsterId,
                        Quantity = m.Quantity
                    })
                    .ToList()
            };

            calculationResult = await Api.CalculateAsync(request);

            if (calculationResult is null)
            {
                statusMessage = "API returned null result";
                return;
            }

            statusMessage = $"Encounter calculated: {calculationResult.Difficulty}";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            statusMessage = "Calculation failed.";
        }
        finally
        {
            isCalculating = false;
        }
    }
    
    private static string FormatCr(decimal cr) => cr switch
    {
        0.125m => "1/8",
        0.25m => "1/4",
        0.5m => "1/2",
        _ => cr.ToString()
    };
    
    private void ResetFilters()
    {
        searchTerm = "";
        selectedSort = "name-asc";
        selectedCrFilter = "";
    }
    
    private void ClearEncounter()
    {
        selectedMonsters.Clear();
        calculationResult = null;
        statusMessage = "Encounter cleared.";
    }
    
    private async Task RecalculateIfPossible()
    {
        if (CanCalculate)
        {
            await CalculateEncounter();
        }
        else
        {
            calculationResult = null;
        }
    }
    
    private async Task OnPartySizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            partySize = value;
            await RecalculateIfPossible();
        }
    }

    private async Task OnPartyLevelChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            partyLevel = value;
            await RecalculateIfPossible();
        }
    }
    
    private IEnumerable<MonsterListItemDto> GetFilteredMonsters()
    {
        IEnumerable<MonsterListItemDto> query = monsters;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(m =>
                m.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(selectedCrFilter) &&
            decimal.TryParse(selectedCrFilter, out var cr))
        {
            query = query.Where(m => m.ChallengeRating == cr);
        }

        query = selectedSort switch
        {
            "name-desc" => query.OrderByDescending(m => m.Name),
            "cr-asc" => query.OrderBy(m => m.ChallengeRating).ThenBy(m => m.Name),
            "cr-desc" => query.OrderByDescending(m => m.ChallengeRating).ThenBy(m => m.Name),
            _ => query.OrderBy(m => m.Name)
        };

        return query;
    }
    
    
    
    
}

